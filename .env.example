# Server
PORT=3001

# zkTLS executable
ZKTLS_PATH=/root/Sendly/zktls-service/zktls/target/release/zktls
# Backend: r0 (Risc0) or sp1
ZKTLS_BACKEND=r0
# Optional: restrict API access
# ZKTLS_API_KEY=your-secret-key

# Reclaim Protocol (required for /api/reclaim/*)
RECLAIM_APP_ID=
RECLAIM_APP_SECRET=
# RECLAIM_APP_CALLBACK_URL=https://your-domain.com/api/reclaim/callback

# Provider IDs (Reclaim Dev Tool)
# RECLAIM_PROVIDER_ID_TWITTER=e6fe962d-8b4e-4ce5-abcc-3d21c88bd64a
# RECLAIM_PROVIDER_ID_GITHUB=
# RECLAIM_PROVIDER_ID_LINKEDIN=
# RECLAIM_PROVIDER_ID_INSTAGRAM=
# RECLAIM_PROVIDER_ID_TWITCH=6eefbc3f-9dd9-4466-a18f-ab9eea03d884
# RECLAIM_PROVIDER_ID_GMAIL=
# RECLAIM_PROVIDER_ID_TELEGRAM=

# Twitter OAuth 2.0
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=

# Twitter OAuth 1.0a (API key/secret)
# TWITTER_API_KEY=
# TWITTER_API_SECRET=

# GitHub OAuth
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# LinkedIn OAuth
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=

# Instagram OAuth
# INSTAGRAM_CLIENT_ID=
# INSTAGRAM_CLIENT_SECRET=

# Google/Gmail OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Twitch OAuth
# TWITCH_CLIENT_ID=

# Telegram (Login Widget + MTProto)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
